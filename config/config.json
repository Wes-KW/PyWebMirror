{
	"user": {
		"dataPath": "/etc/pwm/user.bin",
		"hashPath": "/etc/pwm/user.hash",
		"encrypt": {
			"enable": true,
			"method": "rsa"
		}
	},
	"server": {
		"name": "localhost",
		"port": 443,
		"ssl": {
			"enable": true,
			"certificatePath": "/etc/pwm/local-dev.pem"
		},
		"url": {
			"encrypt": {
				"enable": true,
				"method": "rsa"
			},
			"rules": {
				"allow": [
					"^https?://.+"
				],
				"deny": []
			}
		},
		"debug": true
	}
}